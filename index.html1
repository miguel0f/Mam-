<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BRAND — Nueva Colección</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #000000;
      --white: #ffffff;
      --gray-light: #f7f7f7;
      --gray-mid: #e5e5e5;
      --gray-text: #555555;
      --accent: #dd1d1d;
      --font: 'Poppins', sans-serif;
      --max-width: 1400px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font);
      color: var(--black);
      background: var(--white);
      font-size: 14px;
      line-height: 1.6;
    }

    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    button { font-family: var(--font); cursor: pointer; border: none; outline: none; }

    .container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 32px;
    }

    /* ─── ANNOUNCEMENT BAR ─── */
    .announcement-bar {
      background: var(--black);
      color: var(--white);
      text-align: center;
      padding: 10px 16px;
      font-size: 11px;
      letter-spacing: 1.5px;
      overflow: hidden;
      position: relative;
    }
    .ticker-wrapper { overflow: hidden; white-space: nowrap; }
    .ticker-text {
      display: inline-block;
      animation: ticker 22s linear infinite;
      padding-left: 100%;
    }
    @keyframes ticker {
      0% { transform: translateX(0); }
      100% { transform: translateX(-100%); }
    }

    /* ─── HEADER ─── */
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--white);
      border-bottom: 1px solid var(--gray-mid);
      padding: 16px 0;
      transition: box-shadow 0.3s;
    }
    .header.scrolled { box-shadow: 0 2px 16px rgba(0,0,0,0.08); }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }
    .logo {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 3px;
      flex-shrink: 0;
    }
    nav { display: flex; gap: 28px; }
    nav a {
      font-size: 12px;
      letter-spacing: 0.8px;
      font-weight: 500;
      position: relative;
      padding-bottom: 2px;
    }
    nav a::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 0; height: 1px;
      background: var(--black);
      transition: width 0.3s;
    }
    nav a:hover::after { width: 100%; }
    .header-icons { display: flex; align-items: center; gap: 18px; }
    .header-icons button {
      background: none;
      font-size: 18px;
      position: relative;
    }
    .cart-count {
      position: absolute;
      top: -6px; right: -8px;
      background: var(--accent);
      color: var(--white);
      font-size: 9px;
      font-weight: 700;
      width: 16px; height: 16px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }
    .hamburger { display: none; flex-direction: column; gap: 5px; }
    .hamburger span { display: block; width: 22px; height: 2px; background: var(--black); }

    /* ─── HERO SLIDESHOW ─── */
    .hero {
      background: var(--gray-light);
      min-height: 520px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, #f7f7f7 0%, #ececec 100%);
    }
    .hero-pattern {
      position: absolute;
      inset: 0;
      opacity: 0.04;
      background-image: repeating-linear-gradient(
        45deg,
        #000 0px, #000 1px,
        transparent 1px, transparent 40px
      );
    }
    .hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 48px 32px;
      animation: fadeUp 0.9s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-eyebrow {
      font-size: 11px;
      letter-spacing: 4px;
      font-weight: 600;
      color: var(--gray-text);
      margin-bottom: 16px;
    }
    .hero-title {
      font-size: clamp(36px, 6vw, 72px);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -1px;
      margin-bottom: 16px;
    }
    .hero-subtitle {
      font-size: 14px;
      color: var(--gray-text);
      max-width: 420px;
      margin: 0 auto 32px;
    }
    .hero-buttons { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

    /* ─── BUTTONS ─── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 28px;
      font-size: 11px;
      letter-spacing: 1.5px;
      font-weight: 600;
      border-radius: 4px;
      transition: all 0.25s;
      font-family: var(--font);
      cursor: pointer;
    }
    .btn-primary {
      background: var(--black);
      color: var(--white);
      border: 1.5px solid var(--black);
    }
    .btn-primary:hover { background: #222; transform: translateY(-1px); }
    .btn-outline {
      background: transparent;
      color: var(--black);
      border: 1.5px solid var(--black);
    }
    .btn-outline:hover { background: var(--black); color: var(--white); transform: translateY(-1px); }

    /* ─── ICON BAR ─── */
    .icon-bar {
      border-top: 1px solid var(--gray-mid);
      border-bottom: 1px solid var(--gray-mid);
    }
    .icon-bar-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }
    .icon-item {
      padding: 22px 16px;
      text-align: center;
      border-right: 1px solid var(--gray-mid);
      transition: background 0.2s;
    }
    .icon-item:last-child { border-right: none; }
    .icon-item:hover { background: var(--gray-light); }
    .icon-svg { font-size: 22px; margin-bottom: 6px; }
    .icon-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.5px;
      display: block;
      margin-bottom: 2px;
    }
    .icon-sub { font-size: 10px; color: var(--gray-text); }

    /* ─── SECTIONS ─── */
    .section { padding: 64px 0; }
    .section-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 32px;
    }
    .section-title {
      font-size: 24px;
      font-weight: 700;
      letter-spacing: -0.5px;
    }
    .view-all {
      font-size: 11px;
      letter-spacing: 1px;
      font-weight: 600;
      border-bottom: 1px solid var(--black);
      padding-bottom: 2px;
      transition: opacity 0.2s;
    }
    .view-all:hover { opacity: 0.5; }

    /* ─── PRODUCT GRID ─── */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
    .product-card {
      background: var(--gray-light);
      border-radius: 4px;
      overflow: hidden;
      transition: transform 0.3s;
      position: relative;
    }
    .product-card:hover { transform: translateY(-4px); }
    .product-img-wrap {
      aspect-ratio: 3/4;
      background: #e8e8e8;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .product-placeholder {
      font-size: 48px;
      opacity: 0.25;
    }
    .product-tag {
      position: absolute;
      top: 12px; left: 12px;
      background: var(--accent);
      color: var(--white);
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1px;
      padding: 4px 8px;
      border-radius: 2px;
    }
    .product-quick-add {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      background: rgba(0,0,0,0.85);
      color: var(--white);
      font-size: 10px;
      letter-spacing: 1.5px;
      font-weight: 600;
      padding: 12px;
      text-align: center;
      transform: translateY(100%);
      transition: transform 0.3s;
    }
    .product-card:hover .product-quick-add { transform: translateY(0); }
    .product-info { padding: 14px 16px; }
    .product-vendor {
      font-size: 10px;
      color: var(--gray-text);
      letter-spacing: 1px;
      margin-bottom: 4px;
    }
    .product-name { font-size: 13px; font-weight: 600; margin-bottom: 6px; }
    .product-price { font-size: 14px; font-weight: 700; }
    .product-price-old {
      font-size: 12px;
      color: var(--gray-text);
      text-decoration: line-through;
      margin-right: 6px;
    }
    .product-price-sale { color: var(--accent); }

    /* ─── BANNER CON TEXTO ─── */
    .rich-text-section {
      background: var(--black);
      color: var(--white);
      padding: 80px 32px;
      text-align: center;
    }
    .rich-text-section .eyebrow {
      font-size: 11px;
      letter-spacing: 4px;
      color: #888;
      margin-bottom: 16px;
    }
    .rich-text-section h2 {
      font-size: clamp(28px, 4vw, 48px);
      font-weight: 700;
      margin-bottom: 16px;
      letter-spacing: -1px;
    }
    .rich-text-section p {
      font-size: 14px;
      color: #aaa;
      max-width: 480px;
      margin: 0 auto 28px;
      line-height: 1.8;
    }

    /* ─── COLLAGE / IMAGE ─── */
    .collage-section { padding: 0; }
    .collage-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 400px;
    }
    .collage-left {
      background: var(--gray-light);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 64px 48px;
    }
    .collage-right {
      background: var(--black);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 64px 48px;
      color: var(--white);
    }
    .collage-text h2 {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 12px;
      letter-spacing: -0.5px;
    }
    .collage-text p {
      font-size: 13px;
      line-height: 1.8;
      margin-bottom: 24px;
      opacity: 0.7;
    }

    /* ─── TESTIMONIALS ─── */
    .testimonials-section { background: var(--gray-light); padding: 64px 0; }
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 32px;
    }
    .testi-card {
      background: var(--white);
      border-radius: 4px;
      padding: 28px 24px;
      border: 1px solid var(--gray-mid);
      transition: border-color 0.2s, transform 0.3s;
    }
    .testi-card:hover { border-color: var(--black); transform: translateY(-3px); }
    .stars { font-size: 14px; margin-bottom: 14px; letter-spacing: 2px; }
    .testi-text { font-size: 13px; line-height: 1.7; color: #333; margin-bottom: 18px; font-style: italic; }
    .testi-author { display: flex; align-items: center; gap: 10px; }
    .testi-avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: var(--black);
      color: var(--white);
      font-size: 12px;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .testi-name { font-size: 12px; font-weight: 700; }
    .testi-location { font-size: 10px; color: var(--gray-text); }

    /* ─── NEWSLETTER / EMAIL BANNER ─── */
    .email-banner {
      background: var(--gray-light);
      border-top: 1px solid var(--gray-mid);
      border-bottom: 1px solid var(--gray-mid);
      padding: 56px 32px;
      text-align: center;
    }
    .email-banner h2 { font-size: 26px; font-weight: 700; margin-bottom: 8px; }
    .email-banner p { font-size: 13px; color: var(--gray-text); margin-bottom: 24px; }
    .email-form {
      display: flex;
      gap: 0;
      max-width: 440px;
      margin: 0 auto;
    }
    .email-form input {
      flex: 1;
      padding: 12px 16px;
      border: 1.5px solid var(--black);
      border-right: none;
      font-size: 13px;
      font-family: var(--font);
      outline: none;
      border-radius: 4px 0 0 4px;
    }
    .email-form button {
      background: var(--black);
      color: var(--white);
      padding: 12px 22px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      border-radius: 0 4px 4px 0;
      font-family: var(--font);
      transition: background 0.2s;
    }
    .email-form button:hover { background: #333; }

    /* ─── CONTACT FORM ─── */
    .contact-section { padding: 64px 0; }
    .contact-inner { max-width: 560px; margin: 0 auto; }
    .contact-inner h2 { font-size: 26px; font-weight: 700; margin-bottom: 8px; }
    .contact-inner p { font-size: 13px; color: var(--gray-text); margin-bottom: 28px; }
    .form-group { margin-bottom: 16px; }
    .form-group label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.8px;
      margin-bottom: 6px;
    }
    .form-group input, .form-group textarea, .form-group select {
      width: 100%;
      padding: 11px 14px;
      border: 1px solid rgba(0,0,0,0.35);
      border-radius: 4px;
      font-size: 13px;
      font-family: var(--font);
      outline: none;
      transition: border-color 0.2s;
    }
    .form-group input:focus, .form-group textarea:focus {
      border-color: var(--black);
    }
    .form-group textarea { height: 120px; resize: vertical; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    /* ─── FOOTER ─── */
    footer {
      background: var(--black);
      color: var(--white);
      padding: 56px 0 0;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
      gap: 40px;
      padding-bottom: 40px;
      border-bottom: 1px solid #222;
    }
    .footer-brand .footer-logo {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: 3px;
      margin-bottom: 14px;
    }
    .footer-brand p { font-size: 12px; color: #888; line-height: 1.8; margin-bottom: 20px; }
    .social-links { display: flex; gap: 12px; }
    .social-link {
      width: 34px; height: 34px;
      border: 1px solid #333;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 14px;
      transition: border-color 0.2s, background 0.2s;
    }
    .social-link:hover { border-color: var(--white); background: #111; }
    .footer-col h4 {
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #666;
      margin-bottom: 16px;
      font-weight: 600;
    }
    .footer-col ul { list-style: none; }
    .footer-col ul li { margin-bottom: 10px; }
    .footer-col ul li a {
      font-size: 12px;
      color: #999;
      transition: color 0.2s;
    }
    .footer-col ul li a:hover { color: var(--white); }
    .footer-newsletter input {
      width: 100%;
      background: #111;
      border: 1px solid #333;
      color: var(--white);
      padding: 10px 14px;
      font-size: 12px;
      font-family: var(--font);
      border-radius: 4px;
      outline: none;
      margin-bottom: 10px;
      transition: border-color 0.2s;
    }
    .footer-newsletter input:focus { border-color: #666; }
    .footer-newsletter button {
      width: 100%;
      background: var(--white);
      color: var(--black);
      padding: 10px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      border-radius: 4px;
      font-family: var(--font);
      transition: background 0.2s;
    }
    .footer-newsletter button:hover { background: #ddd; }
    .footer-bottom {
      padding: 20px 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .footer-bottom p { font-size: 11px; color: #555; }
    .payment-icons { display: flex; gap: 8px; }
    .payment-icon {
      background: #111;
      border: 1px solid #333;
      border-radius: 4px;
      padding: 4px 8px;
      font-size: 10px;
      color: #888;
    }

    /* ─── MOBILE MENU ─── */
    .mobile-menu {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 200;
      background: var(--white);
      flex-direction: column;
      padding: 24px;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 40px;
    }
    .mobile-menu nav {
      flex-direction: column;
      gap: 0;
    }
    .mobile-menu nav a {
      font-size: 24px;
      font-weight: 700;
      padding: 14px 0;
      border-bottom: 1px solid var(--gray-mid);
      display: block;
      letter-spacing: -0.5px;
    }
    .close-btn { font-size: 28px; background: none; }

    /* ─── SCROLL REVEAL ─── */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 1024px) {
      .products-grid { grid-template-columns: repeat(2, 1fr); }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      .container { padding: 0 20px; }
      nav { display: none; }
      .hamburger { display: flex; }
      .hero { min-height: 380px; }
      .icon-bar-inner { grid-template-columns: repeat(2, 1fr); }
      .icon-item:nth-child(2) { border-right: none; }
      .products-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
      .collage-grid { grid-template-columns: 1fr; }
      .testimonials-grid { grid-template-columns: 1fr; }
      .email-form { flex-direction: column; }
      .email-form input { border-right: 1.5px solid var(--black); border-bottom: none; border-radius: 4px 4px 0 0; }
      .email-form button { border-radius: 0 0 4px 4px; }
      .footer-grid { grid-template-columns: 1fr; gap: 28px; }
      .footer-bottom { flex-direction: column; gap: 12px; }
      .form-row { grid-template-columns: 1fr; }
      .section { padding: 40px 0; }
    }
  </style>
</head>
<body>

  <!-- ANNOUNCEMENT BAR -->
  <div class="announcement-bar">
    <div class="ticker-wrapper">
      <span class="ticker-text">
        ✦ ENVÍO GRATIS EN COMPRAS MAYORES A $99 &nbsp;&nbsp;&nbsp; ✦ NUEVAS COLECCIONES DISPONIBLES &nbsp;&nbsp;&nbsp; ✦ DEVOLUCIONES GRATIS POR 30 DÍAS &nbsp;&nbsp;&nbsp; ✦ PAGÁ EN CUOTAS SIN INTERÉS &nbsp;&nbsp;&nbsp; ✦ ENVÍO GRATIS EN COMPRAS MAYORES A $99 &nbsp;&nbsp;&nbsp;
      </span>
    </div>
  </div>

  <!-- HEADER -->
  <header class="header" id="header">
    <div class="container">
      <div class="header-inner">
        <a href="#" class="logo">BRAND</a>
        <nav>
          <a href="#inicio">Inicio</a>
          <a href="#coleccion">Colección</a>
          <a href="#nosotros">Nosotros</a>
          <a href="#testimonios">Reviews</a>
          <a href="#contacto">Contacto</a>
        </nav>
        <div class="header-icons">
          <button aria-label="Buscar">
            <svg width="18" height="18" viewBox="0 0 18 19" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M11.03 11.68A5.784 5.784 0 112.85 3.5a5.784 5.784 0 018.18 8.18zm.26 1.12a6.78 6.78 0 11.72-.7l5.4 5.4a.5.5 0 11-.71.7l-5.41-5.4z" fill="currentColor"/></svg>
          </button>
          <button aria-label="Cuenta">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          </button>
          <button aria-label="Carrito" style="position:relative;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            <span class="cart-count">0</span>
          </button>
          <button class="hamburger" aria-label="Menú" onclick="document.getElementById('mobileMenu').classList.add('open')">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu">
    <div class="mobile-menu-header">
      <span class="logo">BRAND</span>
      <button class="close-btn" onclick="document.getElementById('mobileMenu').classList.remove('open')" aria-label="Cerrar">✕</button>
    </div>
    <nav>
      <a href="#inicio" onclick="document.getElementById('mobileMenu').classList.remove('open')">Inicio</a>
      <a href="#coleccion" onclick="document.getElementById('mobileMenu').classList.remove('open')">Colección</a>
      <a href="#nosotros" onclick="document.getElementById('mobileMenu').classList.remove('open')">Nosotros</a>
      <a href="#testimonios" onclick="document.getElementById('mobileMenu').classList.remove('open')">Reviews</a>
      <a href="#contacto" onclick="document.getElementById('mobileMenu').classList.remove('open')">Contacto</a>
    </nav>
  </div>

  <!-- HERO -->
  <section class="hero" id="inicio">
    <div class="hero-bg"></div>
    <div class="hero-pattern"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">TEMPORADA 2026</p>
      <h1 class="hero-title">NUEVA<br>COLECCIÓN</h1>
